@model JokesWebApp.Models.Joke
@{
    ViewData["Title"] = "Delete Joke";
}

<div class="container" style="max-width:560px; margin:0 auto; padding:32px 16px;">
    <h1 class="page-header" style="background:var(--red);">🗑 Delete Joke?</h1>

    <div class="card-joke" style="margin-top:16px; border-color:var(--red);">
        <p style="font-weight:800; font-size:1.1rem; margin-bottom:18px; color:#cc0000;">
            ⚠️ Are you sure you want to delete this joke forever?
        </p>

        <dl style="margin-bottom:20px;">
            <dt style="font-family:'Bangers',cursive; font-size:1.1rem; letter-spacing:1px;">
                @Html.DisplayNameFor(model => model.JokeQuestion)
            </dt>
            <dd style="font-weight:600; margin-bottom:10px;">
                @Html.DisplayFor(model => model.JokeQuestion)
            </dd>

            <dt style="font-family:'Bangers',cursive; font-size:1.1rem; letter-spacing:1px;">
                @Html.DisplayNameFor(model => model.JokeAnswer)
            </dt>
            <dd style="font-weight:600;">
                @Html.DisplayFor(model => model.JokeAnswer)
            </dd>
        </dl>

        <form asp-action="Delete" style="display:flex; gap:12px; flex-wrap:wrap;">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="💀 Yes, Delete It!" class="btn btn-danger" />
            <a asp-action="Index" class="back-link" style="margin-top:0;">← Keep It!</a>
        </form>
    </div>
</div>
